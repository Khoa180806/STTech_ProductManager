@using ProductManager.Authorization
@{
    ViewBag.Title = "Danh sách sản phẩm";
}

@section styles {
    <link rel="stylesheet" href="~/view-resources/Views/Products/Index.css" />
}

@section scripts {
    <script src="~/view-resources/Views/Products/Index.js"></script>
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0 text-dark">@ViewBag.Title</h1>
            </div>
            <div class="col-sm-6 text-right">
                @if (IsGranted(PermissionNames.Pages_Products_Create))
                {
                    <button id="CreateNewProductButton" class="btn btn-primary">
                        <i class="fas fa-plus"></i> Thêm sản phẩm
                    </button>
                }
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <!-- Bộ lọc -->
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Bộ lọc</h3>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3">
                        <input type="text" id="Keyword" class="form-control" placeholder="Tìm kiếm..." />
                    </div>
                    <div class="col-md-2">
                        <select id="CategoryId" class="form-control">
                            <option value="">-- Tất cả danh mục --</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <input type="number" id="MinPrice" class="form-control" placeholder="Giá từ" />
                    </div>
                    <div class="col-md-2">
                        <input type="number" id="MaxPrice" class="form-control" placeholder="Giá đến" />
                    </div>
                    <div class="col-md-3">
                        <button id="SearchButton" class="btn btn-success">
                            <i class="fas fa-search"></i> Tìm kiếm
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bảng dữ liệu -->
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Danh sách sản phẩm</h3>
            </div>
            <div class="card-body">
                <table id="ProductsTable" class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Tên sản phẩm</th>
                            <th>Danh mục</th>
                            <th>Giá</th>
                            <th>Tồn kho</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>
    </div>
</section>

<!-- Modal Thêm/Sửa -->
<div class="modal fade" id="ProductModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="ProductModalLabel">Thêm sản phẩm mới</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form id="ProductForm" role="form" novalidate>
                    <input type="hidden" id="ProductId" />
                    
                    <div class="form-group">
                        <label>Tên sản phẩm <span class="text-danger">*</span></label>
                        <input type="text" id="ProductName" class="form-control" required maxlength="256" />
                    </div>
                    
                    <div class="form-group">
                        <label>Mô tả</label>
                        <textarea id="ProductDescription" class="form-control" rows="3"></textarea>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Giá <span class="text-danger">*</span></label>
                                <input type="number" id="ProductPrice" class="form-control" required min="0" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Tồn kho <span class="text-danger">*</span></label>
                                <input type="number" id="ProductStock" class="form-control" required min="0" />
                            </div>
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label>Danh mục <span class="text-danger">*</span></label>
                        <select id="ProductCategoryId" class="form-control" required>
                            <option value="">-- Chọn danh mục --</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Đóng</button>
                <button type="button" id="SaveProductButton" class="btn btn-primary">
                    <i class="fas fa-save"></i> Lưu
                </button>
            </div>
        </div>
    </div>
</div>