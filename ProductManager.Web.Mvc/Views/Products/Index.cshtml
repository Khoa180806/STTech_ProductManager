@model Abp.Application.Services.Dto.PagedResultDto<ProductManager.Products.Dto.ProductDto>
@using ProductManager.Authorization
@{
    ViewBag.Title = "Danh sách sản phẩm";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0 text-dark">@ViewBag.Title</h1>
            </div>
            <div class="col-sm-6 text-right">
                @if (IsGranted(PermissionNames.Pages_Products_Create))
                {
                    <a href="@Url.Action("Create", "Products")" class="btn btn-primary">
                        <i class="fas fa-plus"></i> Thêm sản phẩm
                    </a>
                }
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Danh sách (@Model.TotalCount sản phẩm)</h3>
            </div>
            <div class="card-body table-responsive p-0">
                <table class="table table-hover table-bordered">
                    <thead>
                        <tr>
                            <th style="width: 50px">#</th>
                            <th>Tên sản phẩm</th>
                            <th>Danh mục</th>
                            <th>Giá</th>
                            <th>Tồn kho</th>
                            <th style="width: 120px">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in Model.Items)
                        {
                            <tr>
                                <td>@product.Id</td>
                                <td>@product.Name</td>
                                <td>@product.CategoryName</td>
                                <td>@product.Price.ToString("N0") đ</td>
                                <td>@product.StockQuantity</td>
                                <td>
                                    @if (IsGranted(PermissionNames.Pages_Products_Edit))
                                    {
                                        <a href="@Url.Action("Edit", "Products", new { id = product.Id })" 
                                           class="btn btn-sm btn-warning">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                    }
                                    @if (IsGranted(PermissionNames.Pages_Products_Delete))
                                    {
                                        <button class="btn btn-sm btn-danger delete-product" 
                                                data-id="@product.Id">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>